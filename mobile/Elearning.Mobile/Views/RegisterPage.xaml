<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Elearning.Mobile.Views.RegisterPage"
    BackgroundColor="#0B0B0B"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.BackButtonBehavior="{StaticResource NoBackButton}">

    <Grid>
        <Border
            BackgroundColor="#1F1F1F"
            Stroke="#2A2A2A"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 14"
            Padding="22"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            WidthRequest="360"
            MaximumWidthRequest="360">

            <Border.Shadow>
                <Shadow
                    Brush="Black"
                    Offset="0,4"
                    Radius="10"
                    Opacity="0.4" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="14">

                <Label
                    Text="Rejestracja"
                    FontSize="28"
                    FontAttributes="Bold"
                    HorizontalTextAlignment="Center"
                    TextColor="White"
                    Margin="0,0,0,6" />

                <Border
                    Background="#3A1C1C"
                    Stroke="#7A2E2E"
                    StrokeShape="RoundRectangle 10"
                    Padding="12"
                    IsVisible="{Binding HasError}">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Błąd rejestracji"
                               FontAttributes="Bold"
                               TextColor="#FFD6D6" />
                        <Label Text="{Binding Error}"
                               TextColor="#FFD6D6" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="6">
                    <Label Text="E-mail" TextColor="#E6E6E6" />
                    <Entry
                        Placeholder="podaj e-mail"
                        Keyboard="Email"
                        Text="{Binding Email}"
                        BackgroundColor="#2A2A2A"
                        TextColor="White"
                        PlaceholderColor="#9A9A9A" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Hasło" TextColor="#E6E6E6" />
                    <Entry
                        Placeholder="podaj hasło"
                        IsPassword="True"
                        Text="{Binding Password}"
                        BackgroundColor="#2A2A2A"
                        TextColor="White"
                        PlaceholderColor="#9A9A9A" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Powtórz hasło" TextColor="#E6E6E6" />
                    <Entry
                        Placeholder="powtórz hasło"
                        IsPassword="True"
                        Text="{Binding ConfirmPassword}"
                        BackgroundColor="#2A2A2A"
                        TextColor="White"
                        PlaceholderColor="#9A9A9A" />
                </VerticalStackLayout>

                <Button
                    Text="Zarejestruj"
                    Command="{Binding RegisterCommand}"
                    BackgroundColor="#14B8A6"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="46" />

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

                <Button
                    Text="Masz konto? Zaloguj się"
                    Command="{Binding GoToLoginCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#14B8A6" />

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
