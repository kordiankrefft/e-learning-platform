<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Elearning.Mobile.Views.LessonsPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Elearning.Mobile.ViewModels"
    xmlns:dtos="clr-namespace:Elearning.Mobile.Dtos.Lesson"
    x:DataType="vm:LessonViewModel"
    BackgroundColor="#0B0B0B"
	Shell.BackButtonBehavior="{StaticResource NoBackButton}">

    <Grid>

        <Grid IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="True"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />
        </Grid>

        <ScrollView IsVisible="{Binding IsNotBusy}">
            <VerticalStackLayout Padding="18" Spacing="14">

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Lekcje"
                               TextColor="White"
                               FontSize="22"
                               FontAttributes="Bold" />

                        <Label Text="{Binding HeaderModuleText}"
                               TextColor="#BDBDBD"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Grid>

                <Border IsVisible="{Binding HasError}"
                        Background="#3A1C1C"
                        Stroke="#7A2E2E"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">
                    <Label Text="{Binding Error}" TextColor="#FFD6D6" />
                </Border>

                <Label Text="Brak lekcji w tym module."
                       TextColor="#BDBDBD"
                       IsVisible="{Binding ShowEmptyLessons}" />

                <VerticalStackLayout
                    Spacing="12"
                    BindableLayout.ItemsSource="{Binding Lessons}"
                    IsVisible="{Binding HasLessons}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="dtos:LessonDto">

                            <Border Background="#121212"
                                    Stroke="#222"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="16">

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                    <Border BackgroundColor="#1F1F1F"
                                            Stroke="#2A2A2A"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 999"
                                            Padding="10,4"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding OrderIndex}"
                                               TextColor="#FACC15"
                                               FontSize="12"
                                               FontAttributes="Bold" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                                        <Label Text="{Binding Title}"
                                               TextColor="White"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <Label Text="{Binding Summary}"
                                               TextColor="#D1D5DB"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Status, StringFormat='Status: {0}'}"
                                                   TextColor="#9CA3AF"
                                                   FontSize="12" />

                                            <BoxView Grid.Column="1"
                                                     WidthRequest="1"
                                                     HeightRequest="12"
                                                     BackgroundColor="#222"
                                                     VerticalOptions="Center" />

                                            <Label Grid.Column="2"
                                                   Text="{Binding EstimatedMinutes, StringFormat='Czas: {0} min'}"
                                                   TextColor="#9CA3AF"
                                                   FontSize="12" />
                                        </Grid>
                                    </VerticalStackLayout>

                                    <Button Grid.Column="2"
                                            Text="Otwórz →"
                                            BackgroundColor="#FACC15"
                                            TextColor="Black"
                                            CornerRadius="999"
                                            HeightRequest="40"
                                            Command="{Binding Source={x:Reference Root}, Path=BindingContext.OpenLessonCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>

                            </Border>

                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
