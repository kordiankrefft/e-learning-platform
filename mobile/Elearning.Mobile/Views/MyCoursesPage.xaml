<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Elearning.Mobile.Views.MyCoursesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Elearning.Mobile.ViewModels.MyCourses"
    BackgroundColor="#0B0B0B"
    Shell.BackButtonBehavior="{StaticResource NoBackButton}">

    <Grid>

        <Grid IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="True"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />
        </Grid>

        <ScrollView IsVisible="{Binding IsNotBusy}">
            <VerticalStackLayout Padding="18" Spacing="14">

                <Label Text="Moje kursy"
                       TextColor="White"
                       FontSize="22"
                       FontAttributes="Bold" />

                <Border IsVisible="{Binding HasError}"
                        Background="#3A1C1C"
                        Stroke="#7A2E2E"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">
                    <Label Text="{Binding Error}" TextColor="#FFD6D6" />
                </Border>

                <Label Text="Nie masz jeszcze żadnych kursów."
                       TextColor="#BDBDBD"
                       IsVisible="{Binding ShowEmptyState}" />

                <Label Text="Aktywne"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       IsVisible="{Binding ShowActiveSection}" />

                <Label Text="Brak aktywnych kursów."
                       TextColor="#BDBDBD"
                       IsVisible="{Binding ShowNoActiveText}" />

                <VerticalStackLayout
                    Spacing="12"
                    BindableLayout.ItemsSource="{Binding ActiveItems}"
                    IsVisible="{Binding ShowActiveSection}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:MyCourseItemViewModel">

                            <Border Background="#121212"
                                    Stroke="#222"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="0">

                                <Grid RowDefinitions="140,*" IsClippedToBounds="True">

                                    <Grid Grid.Row="0" IsClippedToBounds="True">
                                        <Image Source="{Binding ImageUrl}"
                                               Aspect="AspectFill"
                                               HeightRequest="140"
                                               HorizontalOptions="Fill"
                                               VerticalOptions="Fill" />
                                    </Grid>

                                    <VerticalStackLayout Grid.Row="1" Padding="16" Spacing="10">

                                        <Label Text="{Binding Title}"
                                               TextColor="White"
                                               FontSize="16"
                                               FontAttributes="Bold" />

                                        <Label Text="{Binding StatusText}"
                                               TextColor="#D1D5DB"
                                               FontSize="12" />

                                        <Label Text="{Binding AccessStartText}"
                                               TextColor="#9CA3AF"
                                               FontSize="12" />

                                        <Label Text="{Binding AccessEndText}"
                                               TextColor="#9CA3AF"
                                               FontSize="12" />

                                        <HorizontalStackLayout Spacing="10">

                                            <Button Text="Przejdź do kursu →"
                                                    BackgroundColor="#FACC15"
                                                    TextColor="Black"
                                                    CornerRadius="999"
                                                    HeightRequest="40"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenCourseCommand}"
                                                    CommandParameter="{Binding .}" />

                                            <Button Text="Ukończ"
                                                    BackgroundColor="{Binding CompleteButtonBg}"
                                                    TextColor="{Binding CompleteButtonTextColor}"
                                                    CornerRadius="999"
                                                    HeightRequest="40"
                                                    WidthRequest="110"
                                                    IsEnabled="{Binding CanComplete}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CompleteCourseCommand}"
                                                    CommandParameter="{Binding .}" />
                                        </HorizontalStackLayout>

                                        <Label IsVisible="{Binding ShowNoAccessWarning}"
                                               Text="Dostęp wygasł lub został cofnięty."
                                               TextColor="#FCA5A5"
                                               FontSize="12" />

                                        <Label IsVisible="{Binding ShowCheckPassedInfo}"
                                               Text="Sprawdzam, czy zdałeś quiz końcowy..."
                                               TextColor="#9CA3AF"
                                               FontSize="12" />

                                        <Label IsVisible="{Binding ShowNeedQuizHint}"
                                               Text="Aby ukończyć kurs, zdaj quiz z ostatniego modułu."
                                               TextColor="#FACC15"
                                               FontSize="12" />

                                    </VerticalStackLayout>

                                </Grid>
                            </Border>

                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" BackgroundColor="#222" Margin="0,8" />

                <Label Text="Ukończone"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       IsVisible="{Binding ShowCompletedSection}" />

                <Label Text="Brak ukończonych kursów."
                       TextColor="#BDBDBD"
                       IsVisible="{Binding ShowNoCompletedText}" />

                <VerticalStackLayout
                    Spacing="12"
                    BindableLayout.ItemsSource="{Binding CompletedItems}"
                    IsVisible="{Binding ShowCompletedSection}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:MyCourseItemViewModel">

                            <Border Background="#121212"
                                    Stroke="#222"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="0">

                                <Grid RowDefinitions="140,*" IsClippedToBounds="True">

                                    <Grid Grid.Row="0" IsClippedToBounds="True">
                                        <Image Source="{Binding ImageUrl}"
                                               Aspect="AspectFill"
                                               HeightRequest="140"
                                               HorizontalOptions="Fill"
                                               VerticalOptions="Fill" />
                                    </Grid>

                                    <VerticalStackLayout Grid.Row="1" Padding="16" Spacing="10">

                                        <Label Text="{Binding Title}"
                                               TextColor="White"
                                               FontSize="16"
                                               FontAttributes="Bold" />

                                        <Label Text="{Binding CompletedAtText}"
                                               TextColor="#D1D5DB"
                                               FontSize="12" />

                                        <Label Text="{Binding AccessEndText}"
                                               TextColor="#9CA3AF"
                                               FontSize="12" />

                                        <Button Text="Pobierz certyfikat"
                                                BackgroundColor="Transparent"
                                                TextColor="#FACC15"
                                                BorderColor="#FACC15"
                                                BorderWidth="1"
                                                CornerRadius="999"
                                                HeightRequest="40"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DownloadCertificateCommand}"
                                                CommandParameter="{Binding .}" />

                                        <Label IsVisible="{Binding ShowNoAccessWarning}"
                                               Text="Dostęp wygasł lub został cofnięty."
                                               TextColor="#FCA5A5"
                                               FontSize="12" />

                                    </VerticalStackLayout>

                                </Grid>
                            </Border>

                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Button Text="Odśwież"
                        Command="{Binding RefreshCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#FACC15"
                        BorderColor="#FACC15"
                        BorderWidth="1"
                        CornerRadius="12"
                        HeightRequest="44" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>