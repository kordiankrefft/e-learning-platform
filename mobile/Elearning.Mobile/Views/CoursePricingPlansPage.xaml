<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Elearning.Mobile.Views.CoursePricingPlansPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dto="clr-namespace:Elearning.Mobile.Dtos.CoursePricingPlan"
    BackgroundColor="#0B0B0B"
	Shell.BackButtonBehavior="{StaticResource NoBackButton}">

    <Grid>

        <Grid IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="True"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />
        </Grid>

        <ScrollView IsVisible="{Binding IsNotBusy}">
            <VerticalStackLayout Padding="18" Spacing="14">

                <Label Text="Plany cenowe"
                       TextColor="White"
                       FontSize="22"
                       FontAttributes="Bold" />

                <Label Text="{Binding HeaderCourseTitle}"
                       TextColor="#9CA3AF"
                       FontSize="13" />

                <Border IsVisible="{Binding HasError}"
                        Background="#3A1C1C"
                        Stroke="#7A2E2E"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">
                    <Label Text="{Binding Error}" TextColor="#FFD6D6" />
                </Border>

                <Border IsVisible="{Binding HasPurchaseError}"
                        Background="#3A1C1C"
                        Stroke="#7A2E2E"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">
                    <Label Text="{Binding PurchaseError}" TextColor="#FFD6D6" />
                </Border>

                <Label IsVisible="{Binding ShowEmptyPlans}"
                       Text="Brak planów cenowych dla tego kursu."
                       TextColor="#BDBDBD" />

                
                <CollectionView ItemsSource="{Binding PricingPlans}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:CoursePricingPlanDto">
                            <Border Background="#121212"
                                    Stroke="#222"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="16">

                                <VerticalStackLayout Spacing="10">
                                    <Label Text="{Binding Name}"
                                           TextColor="White"
                                           FontSize="16"
                                           FontAttributes="Bold" />

                                    <Label Text="{Binding DescriptionText}"
                                           TextColor="#BDBDBD"
                                           FontSize="13" />

                                    <Label Text="{Binding DurationText, StringFormat='Dostęp: {0}'}"
                                           TextColor="#9CA3AF"
                                           FontSize="12" />

                                    <Button Text="Wybierz plan →"
                                            BackgroundColor="#FACC15"
                                            TextColor="Black"
                                            CornerRadius="999"
                                            HeightRequest="40"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CanPurchase}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectPlanCommand}"
                                            CommandParameter="{Binding .}" />

                                    <ActivityIndicator IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PurchaseLoading}"
                                                       IsRunning="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PurchaseLoading}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
